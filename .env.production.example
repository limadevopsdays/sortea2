# ════════════════════════════════════════════════════════════════
#  PRODUCCIÓN — la fuente de verdad es GitHub Actions.
#  El pipeline (deploy.yml) inyecta lo de la API en el entorno del
#  servicio de Railway con `railway variables --set`, y compila la web
#  con las VITE_*. Railway NO usa un .env físico: la API lee process.env.
#
#  Configúralos en: repo → Settings → Secrets and variables → Actions
# ════════════════════════════════════════════════════════════════

# ───────── Secrets (🔒 sensibles) — inyectados a Railway ─────────
RAILWAY_TOKEN="<project-token-de-railway>"          # autentica el CLI
DATABASE_URL="postgresql://postgres.<ref>:<pwd>@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<pwd>@aws-1-us-east-2.pooler.supabase.com:5432/postgres"
SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"
ORGANIZER_KEY="<una-clave-fuerte>"

# ───────── Variables (📋 no sensibles) ─────────
# Inyectadas a Railway:
SUPABASE_URL="https://<ref>.supabase.co"
AVATAR_BUCKET="avatars"
CORS_ORIGINS="https://<usuario>.github.io"          # origen de Pages, sin path
RAILWAY_SERVICE="<nombre-del-servicio-api>"
# Usadas al compilar la web (Vite):
VITE_API_URL="https://<servicio>.up.railway.app"
VITE_PUBLIC_URL="https://<usuario>.github.io/<repo>"  # el QR codifica ESTA

# Nota: PORT lo inyecta Railway automáticamente; no lo definas.

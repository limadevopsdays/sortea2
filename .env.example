# ─────────────────────────────────────────────────────────────
#  API (NestJS)  ·  apps/api
# ─────────────────────────────────────────────────────────────
# Connection pooler de Supabase (puerto 6543, modo transaction) — para la app
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexión directa (puerto 5432) — solo para migraciones de Prisma
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

API_PORT=3000
# Orígenes permitidos para CORS y WebSocket (coma-separados)
CORS_ORIGINS="http://localhost:5173"

# Clave que el organizador debe enviar para sortear/limpiar (header x-organizer-key).
# Vacío = modo abierto (solo para desarrollo).
ORGANIZER_KEY=""

# Supabase Storage para fotos de avatar (lado servidor, service role)
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""   # Project Settings → API → service_role (¡secreto! va en .env, NO aquí)
AVATAR_BUCKET="avatars"

# ─────────────────────────────────────────────────────────────
#  WEB (React + Vite)  ·  apps/web   (las vars deben empezar con VITE_)
# ─────────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:3000"
# URL pública que codifica el QR (en prod = dominio desplegado del frontend)
VITE_PUBLIC_URL="http://localhost:5173"
